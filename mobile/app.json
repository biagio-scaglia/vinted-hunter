{
  "expo": {
    "name": "V-Hunter",
    "slug": "v-hunter",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#020212"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vhunter.app"
    },
    "android": {
      "permissions": ["android.permission.CAMERA"],
      "package": "com.vhunter.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "V-Hunter uses the camera to scan barcodes and take photos for OCR text extraction."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "V-Hunter accesses your photo library to pick images for OCR text extraction."
        }
      ]
    ]
  }
}
